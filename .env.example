# Adyen test-environment credentials
# Customer Area > Developers > API credentials (ws@Company.YourMerchant)
# Default environment: test (v71 API version)

# API Key of the web service user (used ONLY on the server, never exposed to the browser)
ADYEN_API_KEY=YOUR_TEST_API_KEY

# Merchant account name (e.g. YourCompanyECOM) - NOT the company account
ADYEN_MERCHANT_ACCOUNT=YOUR_MERCHANT_ACCOUNT

# Client Key (starts with test_) - used by the browser SDK.
# IMPORTANT: add http://localhost:8080 to this credential's "Allowed origins".
ADYEN_CLIENT_KEY=test_YOUR_CLIENT_KEY

PORT=8080
